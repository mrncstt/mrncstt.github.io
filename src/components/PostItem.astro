---
interface Props {
  title: string;
  date: Date;
  slug: string;
  readingTime: number;
  tags?: string[];
  til?: boolean;
}
const { title, date, slug, readingTime, tags, til } = Astro.props;
const formatted = date.toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric'
});
---
<a class="post-item" href={`/posts/${slug}/`}>
  <div class="post-item-left">
    <time class="post-date" datetime={date.toISOString()}>{formatted}</time>
    <span class="post-read-time">{readingTime} min read</span>
  </div>
  <div class="post-item-right">
    {til && <span class="til-badge">TIL</span>}
    <span class="post-title-link">{title}</span>
    {tags && tags.length > 0 && (
      <div class="post-item-tags">
        {tags.map(tag => (
          <span class="post-item-tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
