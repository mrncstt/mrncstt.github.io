---
// Loaded only on posts with mermaid: true
// Uses monochrome custom theme that adapts to dark/light
---
<script>
  async function initMermaid() {
    // Convert Shiki-highlighted mermaid code blocks into .mermaid divs.
    // Pull source from <code> so the CopyCode button text never leaks in.
    document.querySelectorAll<HTMLElement>('pre[data-language="mermaid"]').forEach(pre => {
      const code = pre.querySelector('code');
      const lines = code?.querySelectorAll('.line');
      let source = '';
      if (lines && lines.length > 0) {
        source = Array.from(lines).map(l => (l as HTMLElement).innerText).join('\n');
      } else if (code) {
        source = code.innerText;
      }
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = source;
      pre.replaceWith(div);
    });

    const { default: mermaid } = await import('mermaid');

    const style = getComputedStyle(document.documentElement);
    const get = (v: string) => style.getPropertyValue(v).trim();

    mermaid.initialize({
      startOnLoad: false,
      theme: 'base',
      themeVariables: {
        primaryColor: get('--surface'),
        primaryBorderColor: get('--border-hover'),
        primaryTextColor: get('--text-strong'),
        lineColor: get('--text-faint'),
        secondaryColor: get('--bg-elevated'),
        tertiaryColor: get('--surface'),
        fontFamily: 'DM Sans, sans-serif',
        fontSize: '13px',
      },
    });

    await mermaid.run({ querySelector: '.mermaid' });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMermaid);
  } else {
    initMermaid();
  }
</script>
