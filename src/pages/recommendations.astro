<style>
  .recs-page {
    max-width: var(--wide-width);
    margin: 40px auto;
    padding: 56px 64px 80px;
    background: var(--bg-elevated);
    border-radius: 4px;
  }
  @media (max-width: 700px) {
    .recs-page { padding: 32px 24px 48px; margin: 24px auto; }
  }
  .recs-page h1 {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 600;
    color: var(--text-strong);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .recs-intro {
    font-family: var(--font-prose);
    font-size: 16px;
    color: var(--text-muted);
    margin-bottom: 40px;
    line-height: 1.6;
  }
  .recs-section {
    margin-bottom: 36px;
  }
  .recs-section h2 {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    color: var(--text-strong);
    margin-bottom: 14px;
  }
  .recs-section p {
    font-family: var(--font-prose);
    font-size: 15px;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .recs-list {
    list-style: none;
    padding: 0;
  }
  .recs-list li {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text);
    padding: 4px 0;
  }
  .recs-list a {
    color: var(--text-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
  }
  .recs-list a:hover {
    text-decoration-color: var(--text-muted);
  }
  .recs-lang {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--badge-text);
    background: var(--badge-bg);
    padding: 1px 6px;
    border-radius: 3px;
  }
  .recs-table-wrap {
    margin-bottom: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .recs-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 13px;
    table-layout: auto;
    min-width: 540px;
  }
  @media (max-width: 600px) {
    .recs-table { font-size: 12px; min-width: 480px; }
    .recs-table th, .recs-table td { padding: 8px 10px; }
  }
  .recs-table th {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
  }
  .recs-table td {
    padding: 8px 12px;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    word-break: break-word;
  }
  .recs-table a {
    color: var(--text-strong);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--border);
  }
  .recs-table a:hover {
    text-decoration-color: var(--text-muted);
  }
  .recs-note {
    font-size: 13px;
    color: var(--text-faint);
    margin-top: 40px;
  }
</style>
